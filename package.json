{
  "name": "lajvstart",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "start": "astro dev",
    "start:prod": "astro dev --mode production",
    "start:debug": "DEBUG_LOGS=true astro dev",
    "build": "astro build",
    "build:dev": "DEV_BUILD=true astro build",
    "preview": "astro preview",
    "astro": "astro",
    "types": "npx supabase gen types typescript --local > src/types/supabase.ts",
    "supabase": "supabase",
    "migrate": "npx supabase db diff -f",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "npm run test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint --fix --quiet .",
    "fmt:check": "prettier --check .",
    "fmt": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.4.8",
    "@astrojs/check": "^0.9.4",
    "@astrojs/netlify": "^6.5.9",
    "@astrojs/tailwind": "^6.0.2",
    "@supabase/supabase-js": "^2.39.7",
    "alpinejs": "^3.14.1",
    "astro": "^5.13.5",
    "dompurify": "^3.1.7",
    "flowbite": "^2.2.1",
    "jsdom": "^25.0.1",
    "micromatch": "^4.0.5",
    "nodemailer": "^6.9.16",
    "showdown": "^2.1.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-opentype": "^1.1.0",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.3",
    "@eslint/json": "^1.0.1",
    "@types/alpinejs": "^3.13.10",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/micromatch": "^4.0.6",
    "@types/nodemailer": "^6.4.17",
    "@types/showdown": "^2.0.6",
    "@types/simplemde": "^1.11.11",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "lefthook": "^2.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simplemde": "^1.11.2",
    "supabase": "^2.20.12",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18",
    "vitest-create-mock": "^0.0.8"
  },
  "volta": {
    "node": "22.22.0"
  }
}
