{
  "name": "lajvstart",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "start": "astro dev",
    "start:debug": "DEBUG_LOGS=true astro dev",
    "build": "astro check && astro build",
    "build:dev": "astro check && DEV_BUILD=true astro build",
    "preview": "astro preview",
    "astro": "astro",
    "types": "npx supabase gen types typescript --local > src/types/supabase.ts",
    "supabase": "supabase",
    "migrate": "npx supabase db diff -f"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.4.0",
    "@astrojs/check": "^0.9.4",
    "@astrojs/netlify": "^5.5.4",
    "@astrojs/tailwind": "^5.1.2",
    "@supabase/supabase-js": "^2.39.7",
    "alpinejs": "^3.14.1",
    "astro": "^4.16.13",
    "dompurify": "^3.1.7",
    "flowbite": "^2.2.1",
    "jsdom": "^25.0.1",
    "micromatch": "^4.0.5",
    "nodemailer": "^6.9.16",
    "showdown": "^2.1.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-opentype": "^1.1.0",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "prettier": {
    "semi": false
  },
  "devDependencies": {
    "@types/alpinejs": "^3.13.10",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/micromatch": "^4.0.6",
    "@types/nodemailer": "^6.4.17",
    "@types/showdown": "^2.0.6",
    "@types/simplemde": "^1.11.11",
    "@types/uuid": "^9.0.8",
    "supabase": "^1.223.10"
  }
}
