---
import type { HTMLAttributes } from "astro/types"

interface Props extends HTMLAttributes<"input"> {
  label: string
  id: string
  caption?: string | undefined
  size?: "regular" | "small"
}

const {
  class: className,
  label,
  id,
  caption,
  size = "regular",
  required,
  ...rest
} = Astro.props
---

<div class={`w-full ${className}`}>
  {
    rest.type !== "hidden" && (
      <label
        for={id}
        class:list={[
          "block",
          "mb-2",
          "text-sm",
          "font-medium",
          "text-gray-900",
          "dark:text-white",
        ]}
      >
        {label}
        {!required && <span class="text-xs text-gray-500">(valfritt)</span>}
      </label>
    )
  }
  <input
    id={id}
    class:list={[
      "bg-gray-50 border",
      "border-gray-300",
      "text-gray-900",
      ,
      "rounded-lg",
      "focus:ring-blue-500",
      "focus:border-blue-500",
      "block",
      "w-full",
      "dark:bg-gray-700",
      "dark:border-gray-600",
      "dark:placeholder-gray-400",
      "dark:text-white",
      "dark:focus:ring-blue-500",
      "dark:focus:border-blue-500",
      { "p-2.5 text-sm": size === "regular" },
      { "p-2 text-xs": size === "small" },
    ]}
    aria-describedby={`${id}-caption`}
    required={required}
    {...rest}
  />
  {
    rest.maxlength && typeof rest.value !== 'number' && (
      <p class="text-xs text-right text-gray-500">
        <span id={id + "count"}>{rest.value?.length || 0}</span>/{rest.maxlength}
      </p>

      <script is:inline define:vars={{ fieldId: id }}>
        const field = document.querySelector(`#${fieldId}`);
        const counter = document.querySelector(`#${fieldId+'count'}`);
        field.addEventListener('input', (event) => {
          counter.innerHTML = event.target.value.length
        });
      </script>
    )
  }
  {
    caption && (
      <p
        id={`${id}-caption`}
        class="mt-2 text-sm text-gray-500 dark:text-gray-400"
      >
        {caption}
      </p>
    )
  }
</div>
