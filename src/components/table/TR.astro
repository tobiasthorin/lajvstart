---
import type { HTMLAttributes } from "astro/types"

interface Props extends HTMLAttributes<"tr"> {
  status?: "none" | "yellow" | "green"
}
const { status = "none", ...rest } = Astro.props
---

<tr
  class:list={[
    "border-b dark:border-gray-700",
    {
      "odd:bg-white odd:dark:bg-gray-900 even:bg-gray-50 even:dark:bg-gray-800":
        status === "none",
      "odd:bg-yellow-50 odd:dark:bg-yellow-900 even:bg-yellow-100 even:dark:bg-yellow-800":
        status === "yellow",
      "odd:bg-green-50 odd:dark:bg-green-900 even:bg-green-100 even:dark:bg-green-800":
        status === "green",
    },
  ]}
  {...rest}
>
  <slot />
</tr>
