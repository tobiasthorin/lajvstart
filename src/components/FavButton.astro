---
import Button from "./Button.astro"

interface Props {
  eventId: string
  favouriteExists: boolean
}

const { eventId, favouriteExists } = Astro.props
---

<Button hx-post={`/api/favourite/${eventId}`} hx-swap="outerHTML">
  {!favouriteExists ? "Markera som favorit ☆" : "Avmarkera som favorit ★"}
</Button>
