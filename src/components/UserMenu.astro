---
interface Props {
  userName: string
}

const { userName } = Astro.props
---

<div
  class="z-50 hidden my-4 text-base list-none bg-white divide-y divide-gray-100 rounded-lg shadow"
  id="user-dropdown"
>
  <div class="px-4 py-3">
    <span class="block font-bold text-gray-900">
      {userName}
    </span>
  </div>

  <ul aria-labelledby="user-menu-button">
    <li class="text-sm text-gray-700 hover:bg-gray-100">
      <a
        class="block p-2 w-full"
        href="/events/my"
        hx-boost="true"
        hx-target="#main"
      >
        Mina arrangemang
      </a>
    </li>

    <li class="text-sm text-gray-700 hover:bg-gray-100">
      <a
        class="block p-2 w-full"
        href="/events/favourites"
        hx-boost="true"
        hx-target="#main"
      >
        Mina favoriter
      </a>
    </li>

    <li class="text-sm text-gray-700 hover:bg-gray-100">
      <a
        class="block p-2 w-full"
        href="/characters"
        hx-boost="true"
        hx-target="#main"
      >
        Mina karaktärer
      </a>
    </li>

    <li class="text-sm text-gray-700 hover:bg-gray-100">
      <a
        href="/profile"
        hx-boost="true"
        hx-target="#main"
        class="block p-2 w-full"
      >
        Profil
      </a>
    </li>

    <li>
      <form class="block hover:bg-gray-100" action="/api/auth/signout">
        <button class="p-2 w-full text-sm flex text-gray-700" type="submit">
          Logga ut
        </button>
      </form>
    </li>
  </ul>
</div>
