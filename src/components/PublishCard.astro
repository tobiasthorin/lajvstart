---
import type { EventID } from "../services/eventService"
import Button from "./Button.astro"
import Card from "./Card.astro"
import Spinner from "./Spinner.astro"

interface Props {
  published: boolean
  eventId: EventID
}

const { published, eventId } = Astro.props
---

<Card
  id="publishCard"
  title={published ? "Publicerat" : "Inte publicerat"}
  backgroundColor={published ? "bg-green-100" : "bg-red-100"}
>
  <div class="mb-2">
    {
      published
        ? "Ditt event är publicerat och kommer dyka upp i listor och sökningar"
        : "Ditt event är inte publicerat ännu och kommer inte dyka upp i listor och sökningar"
    }
  </div>

  <Button
    hx-put={`/api/event/${eventId}/publish`}
    hx-target="#publishCard"
    hx-swap="outerHTML"
    hx-disabled-elt="this"
  >
    {published ? "Opublicera" : "Publicera nu!"}
    <Spinner size="small" class="inline-block htmx-indicator" />
  </Button>
</Card>
