---
import Button from "../components/Button.astro"
import Input from "../components/Input.astro"
import SignedOutPage from "../layouts/SignedOutPage.astro"
---

<SignedOutPage>
  <main class="flex-1 p-4 flex flex-col items-center">
    <form
      hx-ext="response-targets"
      hx-post="/api/auth/register"
      hx-target-4*="#error-message"
      hx-swap="innerHTML"
      class="mt-32 flex flex-col gap-4 w-72"
    >
      <Input label="Email" type="email" name="email" id="email" required />

      <Input
        label="Password"
        type="password"
        name="password"
        id="password"
        required
      />

      <Button type="submit">Register!</Button>
      <div id="error-message"></div>
    </form>
  </main>
</SignedOutPage>
