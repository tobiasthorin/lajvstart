---
import FavButton from "../../../components/FavButton.astro"
import { toggleFavourite } from "../../../services/favouritesService"

const { eventId } = Astro.params
console.log(Astro.locals)
const userId = Astro.locals.user.id

if (!eventId) return

const favourite = await toggleFavourite(userId, eventId)
---

<FavButton favouriteExists={favourite !== null} eventId={eventId} />
