---
export const partial = true

import RegistrationsTable from "../../../../../components/registrationsTable/registrationsTable.astro"
import { getRegistrations } from "../../../../../services/registrationService"

const { eventId } = Astro.params

if (!eventId) throw new Error("Missing eventId url param")

const registrations = await getRegistrations(eventId)
---

<RegistrationsTable eventId={eventId} registrations={registrations} />
