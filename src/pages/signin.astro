---
import Button from "../components/Button.astro"
import Input from "../components/Input.astro"
import Link from "../components/Link.astro"
import BaseHtml from "../layouts/BaseHtml.astro"

const justRegistered = Astro.url.searchParams.get("registered")
---

<BaseHtml>
  <main class="flex-1 p-4 flex flex-col items-center">
    <header class="p-4 flex justify-center text-5xl font-display">
      <h1
        class="mt-48 text-transparent bg-gradient-to-r from-orange-400 via-orange-500 to-orange-600 bg-clip-text"
      >
        Lajvstart
      </h1>
    </header>
    <form
      hx-post="/api/auth/signin"
      hx-target-4*="#error-message"
      class="mt-32 flex flex-col gap-4 w-72"
    >
      <Input label="Email" type="email" name="email" id="email" required />

      <Input
        label="Lösenord"
        type="password"
        name="password"
        id="password"
        required
      />

      <Button type="submit">Logga in</Button>
      <div id="error-message"></div>
    </form>

    {
        <Link class="mt-8" href="/register">
          Skapa konto
        </Link>
        <Link class="mt-8" href="/forgotPassword">
          Glömt lösenord?
        </Link>
    }

    {
      justRegistered && (
        <p class="mt-8">
          Ett bekräftelsemail har skickats till din inbox.
          Klicka på länken däri och logga sedan in!
        </p>
      )
    }
  </main>
</BaseHtml>
