---
import TopLevelPage from "../../layouts/TopLevelPage.astro"
import { useNamespace, USER_EVENTS_CACHE } from "../../lib/cache"
import { errorResponse as _errorResponse } from "../../utils/responseUtils"
import type { LARPEvent } from "../../types/types"
import { log } from "../../lib/logger"
import { getUpcomingEvents } from "../../services/eventService"
import Table from "../../components/table/Table.astro"
import TableHead from "../../components/table/TableHead.astro"
import TH from "../../components/table/TH.astro"
import TR from "../../components/table/TR.astro"
import TD from "../../components/table/TD.astro"
import Link from "../../components/Link.astro"

const userId = Astro.locals.user.id

const userEventsCache = useNamespace<LARPEvent[]>(USER_EVENTS_CACHE)
let events = userEventsCache.get(userId)

if (!events) {
  log("Getting events from DB")

  events = await getUpcomingEvents()
}
---

<TopLevelPage>
  <h2 class="text-4xl text-orange-500 font-display mb-8">My events</h2>

  <Table id="myEventsTable">
    <TableHead>
      <TH>Event</TH>
      <TH>Start at</TH>
      <TH>Manage</TH>
    </TableHead>

    <tbody>
      {
        events.map((event) => (
          <TR>
            <TD>{event.name}</TD>
            <TD>{event.date_start}</TD>
            <TD>
              <Link
                href={`/events/${event.id}/manage/overview`}
                hx-target="#main"
                hx-boost="true"
              >
                Manage
              </Link>
            </TD>
          </TR>
        ))
      }
    </tbody>
  </Table>
</TopLevelPage>
