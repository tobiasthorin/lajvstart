---
import Card from "../../../../components/Card.astro"
import ManageEvent from "../../../../layouts/ManageEvent.astro"
import { getEvent } from "../../../../services/eventService"
import { getRegistrations } from "../../../../services/registrationService"
import type { LARPEvent } from "../../../../types/types"

const { id } = Astro.params
const userId = Astro.locals.user.id

if (!id) throw new Error("Missing id url param")

let event: LARPEvent

try {
  event = await getEvent(id)
} catch (error) {
  return errorResponse(error)
}

if (event.owner_id !== userId) Astro.redirect("/events")

const registrations = await getRegistrations(event.id)
---

<ManageEvent eventId={event.id}>
  <Card>
    {registrations.length} / {event.maximum_participants}
  </Card>
</ManageEvent>
