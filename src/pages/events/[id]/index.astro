---
import TopLevelPage from "../../../layouts/TopLevelPage.astro"
import type { LARPEvent } from "../../../types/types"
import { getEvent } from "../../../services/eventService"
import FavButton from "../../../components/FavButton.astro"
import {
  getFavourite,
  type Favourite,
} from "../../../services/favouritesService"
import {
  findRegistration,
  type Registration,
} from "../../../services/registrationService"
import { errorResponse as _errorResponse } from "../../../utils/responseUtils"
import type { UserID } from "../../../services/userService"
import showdown from "showdown"
import { JSDOM } from "jsdom"
import DOMPurify from "dompurify"
import { showdownTailwindExtentions } from "../../../utils/markdownUtils"
import { getEventDateString, getFriendlyDate } from "../../../utils/dateUtils"
import { getLowestEventAgeLimit, prettifyURL } from "../../../utils/textUtils"

const { isSignedIn } = Astro.locals
const { id } = Astro.params

if (!id) throw new Error("Missing id url param")

let favourite: Favourite | null = null
let registration: Registration | null = null
let userId: UserID
let event: LARPEvent

try {
  event = await getEvent(id)
} catch (error) {
  return _errorResponse(error)
}

if (isSignedIn) {
  userId = Astro.locals.user.id
  favourite = await getFavourite(userId, event.id)
  registration = await findRegistration(userId, event.id)
}

const window = new JSDOM("").window
const purify = DOMPurify(window)
const cleanDescription = purify.sanitize(event.description)

const converter = new showdown.Converter({
  headerLevelStart: 3,
  extensions: [...showdownTailwindExtentions],
})
const descriptionHTML = converter.makeHtml(cleanDescription)
---

<TopLevelPage>
  <div class="flex flex-col md:flex-row justify-between items-baseline mb-4">
    <h2 class="text-5xl text-orange-500 font-display">{event.name}</h2>
    <p class="text-3xl text-orange-500 font-display">
      {getEventDateString(new Date(event.date_start), new Date(event.date_end))}
    </p>
  </div>

  <img
    src={event.event_banner_url ||
      event.event_image_url ||
      `${import.meta.env.SUPABASE_URL}/storage/v1/object/public/system-files/placeholders/event-placeholder.jpg`}
    alt="Event banner"
    class="w-full aspect-[3] md:aspect-[4.5] object-cover mb-8"
  />

  <div class="flex flex-col-reverse md:flex-row gap-8">
    <article class="flex-[2]" set:html={descriptionHTML} />

    <aside class="flex-[1] flex flex-col gap-4">
      {
        event.external_website_url && (
          <p class="text-center text-white font-display text-2xl bg-cyan-800 rounded border-cyan-950 border p-4">
            <a class="underline" href={event.external_website_url}>
              {prettifyURL(event.external_website_url)}
            </a>
          </p>
        )
      }

      <ul
        class="flex flex-col gap-4 p-4 bg-green-50 rounded border-green-300 border"
      >
        <li>Plats: {event.location_name}</li>
        <li>
          Datum: {
            getEventDateString(
              new Date(event.date_start),
              new Date(event.date_end),
              { monthFormat: "long" }
            )
          }
        </li>

        {
          event.date_signup && (
            <li>
              Sista anmälningsdag:{" "}
              {getFriendlyDate(new Date(event.date_signup))}
            </li>
          )
        }

        {event.prices === null && <p>Gratis</p>}

        {
          event.prices !== null && (
            <li>
              <p>Prisnivåer:</p>
              <ul class="list-disc ml-6">
                {event.prices.map((price) => (
                  <li>
                    <span class="font-bold">{price.price}</span>
                    <span class="text-sm"> SEK</span>
                    {price.description && <span> : {price.description}</span>}
                  </li>
                ))}
              </ul>
            </li>
          )
        }

        <li>Åldersgräns: {getLowestEventAgeLimit(event)}</li>

        <li>
          Taggar: {
            (event.tags || []).map((tag) => (
              <span class="inline-block bg-yellow-100 text-yellow-800 text-xs font-medium me-2 px-2.5 py-0.5 rounded dark:bg-yellow-900 dark:text-yellow-300 capitalize self-start">
                {tag}
              </span>
            ))
          }
        </li>
      </ul>

      {
        isSignedIn && !event.display_mode && (
          <a
            href={`/events/${id}/register`}
            hx-boost="true"
            hx-target="#main"
            class="flex items-center justify-center px-3 py-2 text-2xl font-display tracking-wide text-white bg-cyan-600 rounded-lg hover:bg-cyan-700 focus:ring-4 focus:outline-none focus:ring-cyan-300 dark:bg-cyan-600 dark:hover:bg-cyan-700 dark:focus:ring-cyan-800"
          >
            {registration ? "Ändra anmälan" : "Anmäl mig!"}
          </a>
        )
      }

      {
        isSignedIn && (
          <FavButton favouriteExists={favourite !== null} eventId={event.id} />
        )
      }
    </aside>
  </div>
</TopLevelPage>
