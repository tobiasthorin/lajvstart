---
import Button from "../../components/Button.astro"
import Checkbox from "../../components/Checkbox.astro"
import Input from "../../components/Input.astro"
import Select from "../../components/Select.astro"
import TextArea from "../../components/TextArea.astro"
import TopLevelPage from "../../layouts/TopLevelPage.astro"
import { eventTags } from "../../utils/constants"
---

<TopLevelPage>
  <h2>Create new event</h2>

  <form
    class="flex flex-col gap-4 mb-12"
    method="post"
    action="/api/event"
    hx-boost="true"
    enctype="multipart/form-data"
    hx-target-5*="#error-message"
  >
    <Input
      id="eventName"
      type="text"
      label="Name"
      name="name"
      required
      maxlength="100"
    />

    <Checkbox
      id="isDisplayInput"
      label="Presentational event"
      name="isDisplay"
      caption="This will disable registrations, allowing you to use the event to link to your own registration system and/or website."
    />

    <Input
      id="eventStartDateInput"
      type="date"
      label="Start date"
      name="startDate"
      required
    />

    <Input
      id="eventEndDateInput"
      type="date"
      label="End date"
      name="endDate"
      required
    />

    <Input
      id="finalSignupDateInput"
      type="date"
      label="Final signup date"
      caption="After this date registration will be disabled"
      name="finalSignupDate"
      required
    />

    <Input
      id="eventLocation"
      type="text"
      label="Location"
      name="location"
      required
    />

    <Input
      id="eventLatitude"
      type="text"
      label="Latitude"
      name="latitude"
      required
    />

    <Input
      id="eventLongitude"
      type="text"
      label="Longitude"
      name="longitude"
      required
    />

    <TextArea
      id="eventDescriptionShort"
      label="Short description"
      name="descriptionShort"
      maxlength="200"
    />

    <TextArea id="eventDescription" label="Description" name="description" />

    <Input
      id="eventPicInput"
      type="file"
      label="Event picture"
      name="eventPicture"
      accept=".jpg,.jpeg,.png,.bmp,.webp"
    />

    <Select multiple id="eventTagsInput" label="Tags" name="tags">
      {eventTags.map((tag) => <option value={tag}>{tag}</option>)}
    </Select>

    <Checkbox
      id="eventBeginnerFriendly"
      label="Beginner friendly"
      name="beginnerFriendly"
      caption="This event is suitable for, and welcoming to, people who have never attended a LARP before"
    />

    <Input
      id="ageRestriction"
      type="number"
      label="Lowest age allowed"
      name="ageRestriction"
    />

    <Input
      id="maximumParticipants"
      type="number"
      label="Maximum participants"
      name="maximumParticipants"
    />
    <div class="self-end">
      <Button class="mr-4" type="reset">Clear</Button>
      <Button type="submit">Create!</Button>
    </div>

    <div id="error-message"></div>
  </form>
</TopLevelPage>
