---
import TopLevelPage from "../layouts/TopLevelPage.astro"
import { getUpcomingEvents } from "../services/eventService"
import { errorResponse as _errorResponse } from "../utils/responseUtils"
import { escapeCharacters } from "../utils/textUtils"

const events = await getUpcomingEvents()
if (!events) {
  return _errorResponse("Could not get upcoming events")
}

const locationScripts = events
  .filter(
    (event) =>
      event.location_latitude !== null && event.location_longitude !== null
  )
  .map((event) => {
    const escapedName = escapeCharacters(event.name)
    const escapedLocation = escapeCharacters(event.location_name || "")
    const escapedDescription = escapeCharacters(event.description_short)

    return `L.marker([${event.location_latitude}, ${event.location_longitude}])
    .addTo(map)
    .bindPopup("<h3 class='font-bold text-lg'>${escapedName}</h3> <p>${escapedLocation}</p> <p>${escapedDescription}</p> <p><a href='/events/${event.id}'>Go to event</a></p>");`
  })
---

<TopLevelPage>
  <h2 class="text-4xl text-orange-500 font-display mb-8">
    Hitta lajv nära dig
  </h2>

  <div id="map" class="rounded z-10" style="height: calc(100vh - 190px);"></div>

  <script is:inline>
    var map = L.map("map").setView([61, 14], 6)

    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution:
        '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    }).addTo(map)
  </script>

  {locationScripts.map((script) => <script is:inline set:html={script} />)}
</TopLevelPage>
