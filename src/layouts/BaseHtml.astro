---
import "tailwindcss/base.css"
import "tailwindcss/components.css"
import "tailwindcss/utilities.css"
---

<html lang="en" class="min-h-screen antialiased">
  <head>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>Lajvstart</title>

    <!-- FONTS -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Londrina+Solid&display=swap"
      rel="stylesheet"
    />

    <!-- HTMX -->
    <script is:inline src="/scripts/htmx.min.js"></script>
    <script is:inline async src="/scripts/response-targets.js"></script>

    <!-- LEAFLET -->
    <script is:inline src="/scripts/leaflet.js"></script>
    <link rel="stylesheet" href="/styles/leaflet.css" />
    <script is:inline src="/scripts/leaflet.markercluster.js"></script>
    <link rel="stylesheet" href="/styles/MarkerCluster.css" />
    <link rel="stylesheet" href="/styles/MarkerCluster.Default.css" />

    <!-- SIMPLE MDE -->
    <script is:inline src="/scripts/simplemde.min.js"></script>
    <link rel="stylesheet" href="/styles/simplemde.min.css" />
  </head>
  <body
    hx-ext="response-targets"
    class="min-h-screen flex flex-col bg-gray-50 dark:bg-gray-900"
  >
    <slot />

    <!-- FLOWBITE JS -->
    <script is:inline async src="/scripts/flowbite.min.js"></script>

    <script>
      htmx.onLoad(function () {
        initFlowbite()
      })
    </script>
  </body>
</html>
